{"ast":null,"code":"const resolveDefaultBackendUrl=()=>{if(process.env.REACT_APP_LIVE_BACKEND_URL){return process.env.REACT_APP_LIVE_BACKEND_URL;}if(typeof window==='undefined'){return'http://localhost:10000';}const{hostname,origin}=window.location;if(hostname==='localhost'||hostname==='127.0.0.1'){return'http://localhost:10000';}return`${origin}/_/backend`;};export const LIVE_BACKEND_URL=resolveDefaultBackendUrl();","map":{"version":3,"names":["resolveDefaultBackendUrl","process","env","REACT_APP_LIVE_BACKEND_URL","window","hostname","origin","location","LIVE_BACKEND_URL"],"sources":["C:/Users/IT_center/Documents/GitHub/itcenter/frontend/src/liveBackend.js"],"sourcesContent":["const resolveDefaultBackendUrl = () => {\r\n  if (process.env.REACT_APP_LIVE_BACKEND_URL) {\r\n    return process.env.REACT_APP_LIVE_BACKEND_URL;\r\n  }\r\n\r\n  if (typeof window === 'undefined') {\r\n    return 'http://localhost:10000';\r\n  }\r\n\r\n  const { hostname, origin } = window.location;\r\n\r\n  if (hostname === 'localhost' || hostname === '127.0.0.1') {\r\n    return 'http://localhost:10000';\r\n  }\r\n\r\n  return `${origin}/_/backend`;\r\n};\r\n\r\nexport const LIVE_BACKEND_URL = resolveDefaultBackendUrl();\r\n"],"mappings":"AAAA,KAAM,CAAAA,wBAAwB,CAAGA,CAAA,GAAM,CACrC,GAAIC,OAAO,CAACC,GAAG,CAACC,0BAA0B,CAAE,CAC1C,MAAO,CAAAF,OAAO,CAACC,GAAG,CAACC,0BAA0B,CAC/C,CAEA,GAAI,MAAO,CAAAC,MAAM,GAAK,WAAW,CAAE,CACjC,MAAO,wBAAwB,CACjC,CAEA,KAAM,CAAEC,QAAQ,CAAEC,MAAO,CAAC,CAAGF,MAAM,CAACG,QAAQ,CAE5C,GAAIF,QAAQ,GAAK,WAAW,EAAIA,QAAQ,GAAK,WAAW,CAAE,CACxD,MAAO,wBAAwB,CACjC,CAEA,MAAO,GAAGC,MAAM,YAAY,CAC9B,CAAC,CAED,MAAO,MAAM,CAAAE,gBAAgB,CAAGR,wBAAwB,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
{
  "name": "itcenter",
  "version": "1.0.0",
  "description": "ITCenter - Exam and Proctoring Platform",
  "private": true,
  "scripts": {
    "start": "npm --prefix frontend start",
    "dev": "concurrently \"npm --prefix backend start\" \"npm --prefix frontend start\"",
    "frontend": "npm --prefix frontend start",
    "backend": "npm --prefix backend start",
    "build-frontend": "npm --prefix frontend run build",
    "build-backend": "echo \"No backend build step\"",
    "build": "npm --prefix frontend run build",
    "install-all": "npm install && npm --prefix frontend install && npm --prefix backend install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "exam",
    "proctoring",
    "education",
    "platform"
  ]
}
